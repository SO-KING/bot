TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-from-BotFather
FERNET_KEY=base64-fernet-key-see-readme
HOPX_DEFAULT_TEMPLATE=code-interpreter
HOPX_DEFAULT_TIMEOUT=3600
# Max file size the bot will accept on upload (default 200 MB).
# 209715200 = 200 * 1024 * 1024
TELEGRAM_MAX_FILE_BYTES=209715200
# Optional: point at a local telegram-bot-api server to bypass the
# public 20 MB limit and unlock uploads up to TELEGRAM_MAX_FILE_BYTES.
# Example: http://localhost:8081
# Get one from https://github.com/tdlib/telegram-bot-api — run on VPS
# alongside this bot.
TELEGRAM_LOCAL_API_URL=
